<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FRANMUN | Control Panel</title>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght=700&family=Montserrat:wght=400;600;700&display=swap" rel="stylesheet">
  
  <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js"></script>
  <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-database.js"></script>

  <style>
    :root {
      --primary-dark: #001122;    
      --secondary-blue: #002244;  
      --accent-gold: #dfb72c;     
      --accent-gold-hover: #fcd444;
      --card-bg: rgba(255, 255, 255, 0.04); 
      --card-border: rgba(255, 255, 255, 0.08);
      --text-light: #ffffff;
      --text-muted: #a0aec0;
    }

    body {
      font-family: 'Montserrat', sans-serif;
      background: radial-gradient(circle at top, var(--secondary-blue) 0%, var(--primary-dark) 100%);
      color: var(--text-light);
      min-height: 100vh;
      padding: 40px 20px 100px 20px; /* زيادة السبيس السفلي للشريط */
      display: none;
    }

    .admin-container {
      max-width: 750px;
      margin: 0 auto;
    }

    .admin-card {
      background: rgba(0, 26, 51, 0.95);
      border: 2px solid var(--accent-gold);
      padding: 35px;
      border-radius: 18px;
      box-shadow: 0 25px 50px rgba(0,0,0,0.7);
    }

    h2 {
      font-family: 'Cinzel', Georgia, serif;
      color: var(--accent-gold);
      margin-bottom: 5px;
      letter-spacing: 1px;
    }

    .subtitle {
      font-size: 13px;
      color: var(--text-muted);
      margin-bottom: 25px;
    }

    .admin-form-group {
      margin-bottom: 22px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .admin-form-group label {
      font-weight: 600;
      font-size: 14px;
      color: #cbd5e0;
    }

    .admin-input, .admin-select, .admin-textarea {
      background: rgba(0,0,0,0.4);
      border: 1px solid var(--card-border);
      padding: 12px;
      border-radius: 8px;
      color: #fff;
      font-family: 'Montserrat', sans-serif;
      font-size: 14px;
      width: 100%;
      box-sizing: border-box;
    }

    .admin-input:focus, .admin-select:focus, .admin-textarea:focus {
      outline: none;
      border-color: var(--accent-gold);
    }

    .admin-toggle-box {
      display: flex;
      align-items: center;
      gap: 15px;
      background: rgba(255,255,255,0.02);
      border: 1px solid var(--card-border);
      padding: 14px;
      border-radius: 8px;
      margin-bottom: 15px;
    }

    .admin-toggle-box label {
      font-weight: 600;
      font-size: 14px;
      cursor: pointer;
    }

    .admin-toggle-box input[type="checkbox"] {
      width: 18px;
      height: 18px;
      cursor: pointer;
    }

    .maintenance-highlight {
      background: rgba(231, 76, 60, 0.1);
      border: 1px dashed #e74c3c;
    }

    .coming-soon-highlight {
      background: rgba(223, 183, 44, 0.05);
      border: 1px dashed var(--accent-gold);
    }

    /* 🌟 شريط الحفظ العائم الجديد 🌟 */
    .floating-save-bar {
      position: fixed;
      bottom: -100px;
      left: 50%;
      transform: translateX(-50%);
      width: calc(100% - 40px);
      max-width: 750px;
      background: #112233;
      border: 2px solid var(--accent-gold);
      border-radius: 14px;
      padding: 15px 25px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      box-shadow: 0 -10px 30px rgba(0,0,0,0.5);
      transition: bottom 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      z-index: 9999;
      box-sizing: border-box;
    }

    .floating-save-bar.active {
      bottom: 25px;
    }

    .bar-text h4 {
      margin: 0;
      color: var(--accent-gold);
      font-size: 14px;
    }

    .bar-text p {
      margin: 2px 0 0 0;
      font-size: 11px;
      color: var(--text-muted);
    }

    .bar-buttons {
      display: flex;
      gap: 12px;
    }

    .btn-cancel {
      background: transparent;
      border: 1px solid var(--text-muted);
      color: var(--text-light);
      padding: 10px 20px;
      border-radius: 6px;
      font-weight: 600;
      font-size: 13px;
      cursor: pointer;
    }

    .btn-save {
      background: var(--accent-gold);
      color: var(--primary-dark);
      border: none;
      padding: 10px 22px;
      border-radius: 6px;
      font-weight: 700;
      font-size: 13px;
      cursor: pointer;
      box-shadow: 0 4px 15px rgba(223, 183, 44, 0.2);
    }

    .btn-save:hover {
      background: var(--accent-gold-hover);
    }
  </style>
</head>
<body>

  <div class="admin-container">
    <div class="admin-card">
      <h2>FRANMUN Global Control Panel</h2>
      <p class="subtitle">Modify anything freely. Changes will apply only when you click Sync.</p>
      
      <div class="admin-toggle-box maintenance-highlight">
        <input type="checkbox" id="admMaintenanceMode" onchange="trackLocalChange()">
        <label for="admMaintenanceMode" style="color: #e74c3c; font-weight: bold;">Activate Website Maintenance Mode (Shows Instagram Notice)</label>
      </div>

      <div class="admin-toggle-box">
        <input type="checkbox" id="admChairCheck" onchange="trackLocalChange()">
        <label for="admChairCheck">Chairs Registration (Open / Active)</label>
      </div>
      <div class="admin-toggle-box">
        <input type="checkbox" id="admDelCheck" onchange="trackLocalChange()">
        <label for="admDelCheck">Delegates Registration (Open / Active)</label>
      </div>

      <div class="admin-form-group">
        <label>Conference Target Date:</label>
        <input type="datetime-local" id="admCountDate" class="admin-input" onchange="trackLocalChange()">
      </div>

      <div class="admin-form-group" style="border-top: 1px solid rgba(255,255,255,0.1); padding-top: 20px;">
        <label>Select Committee to Manage:</label>
        <!-- عند تغيير اللجنة، نحفظ بيانات الـ Chair الحالي أولاً حتى لا تضيع -->
        <select id="admCommSelect" class="admin-select" onchange="saveCurrentChairStateTemporarily(); loadCommitteeDataToPanel();">
          <option value="UNWOMEN">UN Women</option>
          <option value="UNHRC">UNHRC</option>
          <option value="DISEC">DISEC</option>
          <option value="WHO">WHO</option>
          <option value="UNHSC">UNHSC</option>
          <option value="CRISIS">Crisis Committee</option>
        </select>
      </div>

      <div class="admin-toggle-box coming-soon-highlight">
        <input type="checkbox" id="admChairsComingSoon" onchange="trackLocalChange()">
        <label for="admChairsComingSoon" style="color: var(--accent-gold);">Hide Chairs and Show "TOP SECRET" Stamp for this Committee</label>
      </div>

      <div class="admin-form-group">
        <label>Committee Topic Title:</label>
        <textarea id="admCommTopic" class="admin-textarea" rows="3" placeholder="Enter the official topic description for this committee..." oninput="trackLocalChange()"></textarea>
      </div>

      <div class="admin-form-group">
        <label>Search Report URL:</label>
        <input type="url" id="admCommReportUrl" class="admin-input" placeholder="https://example.com/report.pdf" oninput="trackLocalChange()">
      </div>

      <div class="admin-form-group" style="border-top: 1px solid rgba(255,255,255,0.05); padding-top: 15px;">
        <label>Select Chair to Modify:</label>
        <!-- نفس الشيء عند الانتقال بين Chairs اللحنة الواحدة -->
        <select id="admChairSelect" class="admin-select" onchange="saveCurrentChairStateTemporarily(); loadSelectedChairBioToPanel();">
        </select>
      </div>

      <div class="admin-form-group">
        <label>Chair Display Name:</label>
        <input type="text" id="admChairNameInput" class="admin-input" placeholder="Chair Full Name" oninput="trackLocalChange()">
      </div>

      <div class="admin-form-group">
        <label>Chair Biography Text:</label>
        <textarea id="admChairTextArea" class="admin-textarea" rows="4" oninput="trackLocalChange()"></textarea>
      </div>
    </div>
  </div>

  <!-- 🌟 عنصر شريط الحفظ العائم التلقائي 🌟 -->
  <div id="floatingSaveBar" class="floating-save-bar">
    <div class="bar-text">
      <h4>Unsaved Changes Detected</h4>
      <p>You have made updates on the panel. Click sync to push changes live.</p>
    </div>
    <div class="bar-buttons">
      <button class="btn-cancel" onclick="discardLocalChanges()">Discard</button>
      <button class="btn-save" onclick="saveAdminSettings()">Global Sync & Save</button>
    </div>
  </div>

  <script>
    // --- FIREBASE CONFIGURATION ---
    const firebaseConfig = {
      apiKey: "AIzaSyBTMBi7k8XzwrNk5MERo7LXtApvhAid08E",
      authDomain: "franmun-f5498.firebaseapp.com",
      databaseURL: "https://franmun-f5498-default-rtdb.firebaseio.com",
      projectId: "franmun-f5498",
      storageBucket: "franmun-f5498.firebasestorage.app",
      messagingSenderId: "574017816071",
      appId: "1:574017816071:web:1968d9a793dec6a6cacca2",
      measurementId: "G-WRXCD54P71"
    };

    firebase.initializeApp(firebaseConfig);
    const database = firebase.database();
    
    let originalData = {}; // لحفظ النسخة القادمة من السيرفر كمرجع للـ Discard
    let appData = {};      // الـ Draft Object الذي نجمع فيه كل التعديلات اللحظية
    let currentChairKey = ""; // لملاحقة الـ Chair المفتوح حالياً قبل التغيير

    window.onload = function() {
      const password = prompt("Enter Administration Password to access Control Panel:");
      if (password === "1234") {
        document.body.style.display = "block";
        initializePanelFetch();
      } else {
        alert("Access Denied! Wrong Password.");
        window.location.href = "index.html";
      }
    };

    function initializePanelFetch() {
      database.ref("homepage_data").once("value", (snapshot) => {
        if (snapshot.exists()) {
          originalData = snapshot.val();
          // نعمل كولون/نسخة عميقة حتى لا نعدل على الأصل في الذاكرة مباشرة
          appData = JSON.parse(JSON.stringify(originalData));
          loadSettingsToAdminPanel();
        }
      });
    }

    function loadSettingsToAdminPanel() {
      document.getElementById("admMaintenanceMode").checked = appData.maintenanceMode || false;
      document.getElementById("admChairCheck").checked = appData.chairsOpen || false;
      document.getElementById("admDelCheck").checked = appData.delegatesOpen || false;
      
      if(appData.targetDate) {
        const d = new Date(appData.targetDate);
        if(!isNaN(d.getTime())) {
          const tzoffset = (new Date()).getTimezoneOffset() * 60000;
          document.getElementById("admCountDate").value = (new Date(d - tzoffset)).toISOString().slice(0, 16);
        }
      }
      loadCommitteeDataToPanel();
    }

    function loadCommitteeDataToPanel() {
      const commKey = document.getElementById("admCommSelect").value;
      const committee = appData.committees[commKey];
      if(!committee) return;
      
      document.getElementById("admCommTopic").value = committee.topics || "";
      document.getElementById("admCommReportUrl").value = committee.report || "";
      document.getElementById("admChairsComingSoon").checked = committee.chairsComingSoon || false;

      const chairSelect = document.getElementById("admChairSelect");
      let optionsHTML = "";

      if(committee.chairs) {
        committee.chairs.forEach((chair, idx) => {
          optionsHTML += `<option value="chairs_${idx}">${chair.name}</option>`;
        });
      }

      if (commKey === "CRISIS" && committee.backroom) {
        committee.backroom.forEach((bChair, idx) => {
          optionsHTML += `<option value="backroom_${idx}">${bChair.name} (Backroom)</option>`;
        });
      }

      chairSelect.innerHTML = optionsHTML;
      loadSelectedChairBioToPanel();
    }

    function loadSelectedChairBioToPanel() {
      const commKey = document.getElementById("admCommSelect").value;
      const chairVal = document.getElementById("admChairSelect").value;
      
      // حفظ المفتاح الحالي لنعرف أين نسجل التعديل لاحقاً
      currentChairKey = chairVal;

      if(!chairVal) {
        document.getElementById("admChairNameInput").value = "";
        document.getElementById("admChairTextArea").value = "";
        return;
      }

      const parts = chairVal.split("_");
      const type = parts[0]; 
      const index = parseInt(parts[1]);
      const committee = appData.committees[commKey];

      if(type === "backroom") {
        document.getElementById("admChairNameInput").value = committee.backroom[index].name || "";
        document.getElementById("admChairTextArea").value = committee.backroom[index].bio || "";
      } else {
        document.getElementById("admChairNameInput").value = committee.chairs[index].name || "";
        document.getElementById("admChairTextArea").value = committee.chairs[index].bio || "";
      }
    }

    // 🌟 دالة هامة جداً: تحفظ أي تعديل للـ Chair في الـ Object المحلي قبل التبديل للجنة أو تشير آخر
    function saveCurrentChairStateTemporarily() {
      const commKey = document.getElementById("admCommSelect").value;
      if(!currentChairKey || !appData.committees[commKey]) return;

      const parts = currentChairKey.split("_");
      const type = parts[0]; 
      const index = parseInt(parts[1]);

      const updatedName = document.getElementById("admChairNameInput").value;
      const updatedBio = document.getElementById("admChairTextArea").value;

      if(type === "backroom" && appData.committees[commKey].backroom) {
        appData.committees[commKey].backroom[index].name = updatedName;
        appData.committees[commKey].backroom[index].bio = updatedBio;
      } else if(type === "chairs" && appData.committees[commKey].chairs) {
        appData.committees[commKey].chairs[index].name = updatedName;
        appData.committees[commKey].chairs[index].bio = updatedBio;
      }
    }

    // فحص التغييرات اللحظية ومقارنتها بالأصل لتفعيل أو إخفاء الـ Bar السفلي
    function trackLocalChange() {
      // نقوم بتحديث الـ Object العام بالقيم السطحية أولاً للفحص الدقيق
      appData.maintenanceMode = document.getElementById("admMaintenanceMode").checked;
      appData.chairsOpen = document.getElementById("admChairCheck").checked;
      appData.delegatesOpen = document.getElementById("admDelCheck").checked;
      
      const dateVal = document.getElementById("admCountDate").value;
      if(dateVal) {
        const d = new Date(dateVal);
        appData.targetDate = `${d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })} ${d.toTimeString().split(' ')[0]}`;
      }

      const commKey = document.getElementById("admCommSelect").value;
      if(appData.committees[commKey]) {
        appData.committees[commKey].topics = document.getElementById("admCommTopic").value;
        appData.committees[commKey].report = document.getElementById("admCommReportUrl").value;
        appData.committees[commKey].chairsComingSoon = document.getElementById("admChairsComingSoon").checked;
      }

      // ترحيل بيانات التشير المفتوح حالياً أيضاً لغايات المقارنة
      saveCurrentChairStateTemporarily();

      // مقارنة الـ Object الحالي مع السيرفر الأصلي
      const isDifferent = JSON.stringify(appData) !== JSON.stringify(originalData);
      
      if(isDifferent) {
        document.getElementById("floatingSaveBar").classList.add("active");
      } else {
        document.getElementById("floatingSaveBar").classList.remove("active");
      }
    }

    // إلغاء كافة التغييرات المعلقة والعودة للأصل
    function discardLocalChanges() {
      if(confirm("Are you sure you want to discard all pending changes?")) {
        appData = JSON.parse(JSON.stringify(originalData));
        loadSettingsToAdminPanel();
        document.getElementById("floatingSaveBar").classList.remove("active");
      }
    }

    // الحفظ النهائي الكلي بـ Single Request لقاعدة البيانات
    function saveAdminSettings() {
      // حفظ حالة المدخلات الأخيرة كخطوة احتياطية نهائية
      appData.maintenanceMode = document.getElementById("admMaintenanceMode").checked;
      appData.chairsOpen = document.getElementById("admChairCheck").checked;
      appData.delegatesOpen = document.getElementById("admDelCheck").checked;
      
      const dateVal = document.getElementById("admCountDate").value;
      if(dateVal) {
        const d = new Date(dateVal);
        appData.targetDate = `${d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })} ${d.toTimeString().split(' ')[0]}`;
      }

      const commKey = document.getElementById("admCommSelect").value;
      if(!appData.committees[commKey]) appData.committees[commKey] = {};
      
      appData.committees[commKey].topics = document.getElementById("admCommTopic").value;
      appData.committees[commKey].report = document.getElementById("admCommReportUrl").value;
      appData.committees[commKey].chairsComingSoon = document.getElementById("admChairsComingSoon").checked;

      // ترحيل بيانات التشير النهائي المفتوح قبل الضغط على الحفظ
      saveCurrentChairStateTemporarily();

      // إرسال كائن التعديلات بالكامل دفعة واحدة إلى قاعدة البيانات
      database.ref("homepage_data").set(appData).then(() => {
        alert("Global Sync Completed Successfully! 🎉 All features updated.");
        originalData = JSON.parse(JSON.stringify(appData)); // تحديث المرجع الأصلي ليطابق الحالي
        document.getElementById("floatingSaveBar").classList.remove("active");
        loadCommitteeDataToPanel();
      }).catch((err) => {
        alert("Error saving data: " + err.message);
      });
    }
  </script>
</body>
</html>
